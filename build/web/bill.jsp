<%@page contentType="text/html" pageEncoding="UTF-8"%>
<%@page import="model.Reservation"%>

<%
    Reservation r = (Reservation) request.getAttribute("reservation");
%>

<!DOCTYPE html>
<html>
<head>
    <title>Reservation Bill</title>
    <meta charset="UTF-8"/>

    <style>
        body{
            font-family: Arial, sans-serif;
            background:#f6f7fb;
            margin:0;
            padding:30px;
            color:#1f2937;
        }

        .container{
            max-width:900px;
            margin:auto;
            background:#fff;
            border-radius:12px;
            box-shadow:0 10px 25px rgba(0,0,0,0.08);
            overflow:hidden;
        }

        .header{
            padding:22px 28px;
            background:linear-gradient(90deg,#0d6efd,#1e40af);
            color:white;
        }

        .header h1{
            margin:0;
            font-size:22px;
            letter-spacing:0.3px;
        }
        .header p{
            margin:6px 0 0;
            opacity:0.9;
            font-size:13px;
        }

        .content{
            padding:26px 28px 10px;
        }

        .topRow{
            display:flex;
            justify-content:space-between;
            gap:20px;
            flex-wrap:wrap;
        }

        .card{
            flex:1;
            min-width:280px;
            border:1px solid #e5e7eb;
            border-radius:10px;
            padding:16px;
            background:#fafafa;
        }

        .card h3{
            margin:0 0 12px;
            font-size:14px;
            color:#374151;
            text-transform:uppercase;
            letter-spacing:0.4px;
        }

        .row{
            display:flex;
            justify-content:space-between;
            padding:8px 0;
            border-bottom:1px dashed #e5e7eb;
            font-size:14px;
        }
        .row:last-child{ border-bottom:none; }

        .label{ color:#6b7280; }
        .value{ font-weight:600; }

        .summary{
            margin-top:18px;
            border:1px solid #e5e7eb;
            border-radius:10px;
            padding:18px;
            background:#ffffff;
        }

        .totalLine{
            display:flex;
            justify-content:space-between;
            align-items:center;
            margin-top:8px;
            padding-top:12px;
            border-top:2px solid #e5e7eb;
            font-size:18px;
            font-weight:700;
        }

        .badge{
            display:inline-block;
            padding:4px 10px;
            border-radius:999px;
            font-size:12px;
            font-weight:700;
            background:#e0f2fe;
            color:#075985;
        }

        .footer{
            padding:14px 28px 24px;
            display:flex;
            justify-content:space-between;
            align-items:center;
            flex-wrap:wrap;
            gap:10px;
        }

        .btn{
            border:none;
            padding:10px 16px;
            border-radius:10px;
            font-weight:700;
            cursor:pointer;
            font-size:14px;
        }
        .btnPrint{ background:#0d6efd; color:white; }
        .btnBack{ background:#6b7280; color:white; text-decoration:none; display:inline-block; }

        .note{
            font-size:12px;
            color:#6b7280;
        }

        /* Print Styling */
        @media print{
            body{ background:white; padding:0; }
            .container{ box-shadow:none; border-radius:0; }
            .footer{ display:none; }
            .card, .summary{ background:white; }
        }
    </style>
</head>

<body>

<div class="container">

    <div class="header">
        <h1>Ocean View Resort - Reservation Bill</h1>
        <p>Galle, Sri Lanka • Contact: +94 XX XXX XXXX • Generated by Room Reservation System</p>
    </div>

    <div class="content">

        <div class="topRow">
            <div class="card">
                <h3>Reservation</h3>
                <div class="row">
                    <div class="label">Reservation ID</div>
                    <div class="value"><%= r.getReservationId() %></div>
                </div>
                <div class="row">
                    <div class="label">Room Type</div>
                    <div class="value">
                        <span class="badge"><%= r.getRoomType() %></span>
                    </div>
                </div>
                <div class="row">
                    <div class="label">Check-in</div>
                    <div class="value"><%= r.getCheckinDate() %></div>
                </div>
                <div class="row">
                    <div class="label">Check-out</div>
                    <div class="value"><%= r.getCheckoutDate() %></div>
                </div>
            </div>

            <div class="card">
                <h3>Guest</h3>
                <div class="row">
                    <div class="label">Guest Name</div>
                    <div class="value"><%= r.getGuestName() %></div>
                </div>
                <div class="row">
                    <div class="label">Address</div>
                    <div class="value"><%= r.getAddress() %></div>
                </div>
                <div class="row">
                    <div class="label">Contact</div>
                    <div class="value"><%= r.getContact() %></div>
                </div>
            </div>
        </div>

        <div class="summary">
            <div class="row">
                <div class="label">Bill Amount (Rs.)</div>
                <div class="value"><%= r.getTotalBill() %></div>
            </div>

            <div class="totalLine">
                <div>Total Payable</div>
                <div>Rs. <%= r.getTotalBill() %></div>
            </div>
        </div>

    </div>

    <div class="footer">
        <div class="note">
            Note: Please keep this bill for future reference. Payment is based on room type and number of nights.
        </div>

        <div>
            <button class="btn btnPrint" onclick="window.print()">Print Bill</button>
            <a class="btn btnBack" href="ViewReservationServlet">Back</a>
        </div>
    </div>

</div>

</body>
</html>